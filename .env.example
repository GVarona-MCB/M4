# === Puertos (fijos, para no chocar con n8n) ===
API_PORT=3001
WEB_PORT=3002

# === Base de datos (PostgreSQL 16, host 5433) ===
DATABASE_URL=postgresql://vianda:vianda@localhost:5433/vianda?schema=public
# En producción agregar: &sslmode=require

# === Zona horaria de las reglas de negocio (GMT-3, sin DST) ===
APP_TIMEZONE=America/Argentina/Buenos_Aires

# === Sesión ===
SESSION_COOKIE_NAME=vianda_session
SESSION_TTL_MINUTES=15
# Tope de vida absoluto de la sesión (más allá de la inactividad)
SESSION_ABSOLUTE_TTL_HOURS=12
# secure=true solo en producción (HTTPS)
SESSION_SECURE=false
CSRF_SECRET=cambiar-en-produccion

# === SMTP (TLS) — único canal de notificación ===
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=vianda@empresa.local
SMTP_REQUIRE_TLS=true

# === Web ===
NEXT_PUBLIC_API_URL=http://localhost:3001
